generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  name            String
  email           String           @unique
  passwordHash    String
  refreshSessions RefreshSession[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model RefreshSession {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Tribunal {
  id        Int       @id @default(autoincrement())
  name      String
  sigla     String    @unique
  syncedAt  DateTime  @default(now())
  processes Process[]
}

model Process {
  id             String          @id @default(cuid())
  number         String          @unique
  className      String?
  classCode      String?
  tribunalId     Int
  tribunal       Tribunal        @relation(fields: [tribunalId], references: [id])
  hasTransitado  Boolean         @default(false)
  communications Communication[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([tribunalId])
}

model Communication {
  id                  String      @id @default(cuid())
  pjeId               Int         @unique
  processId           String
  process             Process     @relation(fields: [processId], references: [id])
  publicationDate     DateTime
  type                String
  content             String
  organName           String?
  medium              String?
  link                String?
  documentType        String?
  communicationNumber Int?
  hash                String?     @unique
  active              Boolean     @default(true)
  aiSummary           String?
  aiSummaryGeneratedAt DateTime?
  recipients          Recipient[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([processId])
  @@index([publicationDate])
}

model Recipient {
  id              String        @id @default(cuid())
  communicationId String
  communication   Communication @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  name            String
  type            String
  role            String?
  oabNumber       String?
  oabState        String?
  createdAt       DateTime      @default(now())

  @@index([communicationId])
}

model SyncLog {
  id             String    @id @default(cuid())
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  status         String
  recordsFetched Int       @default(0)
  recordsSaved   Int       @default(0)
  errorMessage   String?
}
